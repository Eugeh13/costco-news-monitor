# Costco News Monitor — Environment Variables
# Copy this file to .env and fill in your values

# AI Provider: "openai" or "anthropic"
AI_PROVIDER=openai
AI_MODEL=gpt-5-mini

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Anthropic (optional, only if AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Maps Geocoding API — server-side, no HTTP referrer restriction (used by scheduler/worker)
GOOGLE_MAPS_API_KEY=
# Google Maps JavaScript API — browser-side, restrict to your Railway domain via HTTP referrer
GOOGLE_MAPS_BROWSER_KEY=

# Telegram notifications
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# PostgreSQL (Railway provides this)
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# Twitter/X (cookie-based, no API key needed)
# Get from Chrome DevTools → Application → Cookies → x.com
# Cookies expire every ~30 days, update when scraping stops working
TWITTER_AUTH_TOKEN=your-auth-token-cookie
TWITTER_CT0=your-ct0-cookie

# Monitoring settings
RADIUS_KM=5.0
MAX_AGE_HOURS=1
